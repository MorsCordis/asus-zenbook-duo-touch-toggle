[Unit]
Description=Zenbook Duo Auto-Wallpaper Switcher
After=graphical-session.target zenbook-duo-user.service
Wants=graphical-session.target zenbook-duo-user.service

[Service]
Type=simple
ExecStart=/bin/bash "%h/projects/touch toggle/auto-wallpaper.sh"
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
